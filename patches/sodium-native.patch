diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7a7cc987d75deb7e82e480cba0773916b22530b0..a4a2effed8e831c5aa81665eed87ed70d6662ac0 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,3 +1,19 @@
+# Compatibility settings for Windows 10 and newer
+if(WIN32)
+  # Target Windows 10
+  add_compile_definitions(_WIN32_WINNT=0x0A00)
+  if(MSVC OR "${CMAKE_CXX_COMPILER_ID}" MATCHES "Clang")
+    # Arch‑aware tweaks
+    if(CMAKE_SYSTEM_PROCESSOR MATCHES "AMD64|x86_64")
+      add_compile_options(/arch:AVX /Zc:__cplusplus)
+      # Pin Windows SDK version
+      set(CMAKE_SYSTEM_VERSION "10.0.19041.0")
+    elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64")
+      add_compile_options(/Zc:__cplusplus)
+    endif()
+  endif()
+endif()
+
 cmake_minimum_required(VERSION 3.25)
 
 find_package(cmake-bare REQUIRED PATHS node_modules/cmake-bare)
