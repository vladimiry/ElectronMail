{
  "extends": "./tsconfig.checks.json",
  "compilerOptions": {
    // resolving & capabilities
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    // emitting
    "target": "ESNext",
    "module": "ESNext",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "noEmitOnError": true,
    "sourceMap": true,
    // paths
    "rootDir": ".",
    "outDir": "./app",
    "paths": {
      "patches/*": ["./patches/*"],
      "scripts/*": ["./scripts/*"],
      "src/*": ["./src/*"],
      "webpack-configs/*": ["./webpack-configs/*"],
      "package.json": ["./package.json"]
    },
    // types & libs
    "types": [
      "*" // TODO TS=>6/7: explicilty list "compilerOptions.types" items
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./src/@types"
    ],
    "lib": [
      "es2015",
      "es2017.object",
      "es2021.string",
      "es2016.array.include",
      "dom"
    ],
    "plugins": [
      {
        "transform": "typescript-transform-paths"
      },
      {
        "name": "@typescript-nameof/nameof"
      },
      {
        "transform": "@typescript-nameof/nameof"
      },
      {
        "transform": "ts-transformer-keys/transformer"
      }
    ]
  },
  "include": [
    "scripts/**/*",
    "src/**/*",
    "webpack-configs/**/*"
  ]
}
