-                error: new Error('No searcher available'),
-            });
-            onEvent?.({ type: 'done' });
-            return;
-        }
-        try {
-            for await (const item of this.searcher.performSearch(query)) {
-                onEvent?.({ type: 'item', ...item });
-            }
-            this.searchMetrics?.markSearchQuerySucceeded({ durationInSeconds: stopTimer() });
